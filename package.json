{
  "name": "@azex-ai/hive",
  "version": "0.1.0",
  "description": "AI Agent Control Plane — orchestrate coding agents (Claude Code, Codex) with automated quality gates, repair loops, and workspace management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azex-ai/hive"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "codex",
    "orchestration",
    "pipeline",
    "quality-gates",
    "coding-assistant",
    "multi-agent",
    "nextjs",
    "developer-tools"
  ],
  "scripts": {
    "dev": "next dev --port 58080",
    "build": "next build",
    "start": "next start --port 58080",
    "lint": "next lint",
    "serve": "next dev --port 58080",
    "test": "vitest run",
    "test:unit": "vitest run --testPathPattern='(supervisor|runtime-profiles)\\.test'",
    "test:integration": "vitest run --testPathPattern='api-integration\\.test'"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@base-ui/react": "^1.2.2",
    "better-sqlite3": "^11.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "execa": "^9.5.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/uuid": "^10.0.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
